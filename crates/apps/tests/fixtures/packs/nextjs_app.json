{
  "pack_id": "nextjs-app-basic",
  "version": "1",
  "entry_goal": "implement one bounded Next.js app task",
  "recommended_verifier_flow": ["lint", "generic", "test", "build"],
  "allowed_tools": [
    { "operation": "read_file", "scope": "workspace" },
    { "operation": "run_command", "scope": "workspace" }
  ],
  "verifier_rules": [
    {
      "label": "lint",
      "profile": "lint",
      "command": { "program": "npm", "args": ["run", "lint"] },
      "artifact_expectation": "lint succeeds",
      "required": true
    },
    {
      "label": "typecheck",
      "profile": "generic",
      "command": { "program": "npm", "args": ["run", "typecheck"] },
      "artifact_expectation": "typecheck succeeds",
      "required": true
    },
    {
      "label": "test",
      "profile": "test",
      "command": { "program": "npm", "args": ["test"] },
      "artifact_expectation": "tests succeed",
      "required": true
    },
    {
      "label": "build",
      "profile": "build",
      "command": { "program": "npm", "args": ["run", "build"] },
      "artifact_expectation": "build succeeds",
      "required": true
    }
  ],
  "approval_mode": "never"
}
