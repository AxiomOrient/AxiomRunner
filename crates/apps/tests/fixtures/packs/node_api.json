{
  "pack_id": "node-api-basic",
  "version": "1",
  "entry_goal": "implement one bounded Node API task",
  "recommended_verifier_flow": ["generic", "lint", "test", "build"],
  "allowed_tools": [
    { "operation": "read_file", "scope": "workspace" },
    { "operation": "run_command", "scope": "workspace" }
  ],
  "verifier_rules": [
    {
      "label": "install",
      "profile": "generic",
      "command": { "program": "npm", "args": ["install", "--ignore-scripts"] },
      "artifact_expectation": "npm install succeeds",
      "required": true
    },
    {
      "label": "lint",
      "profile": "lint",
      "command": { "program": "npm", "args": ["run", "lint"] },
      "artifact_expectation": "lint succeeds",
      "required": true
    },
    {
      "label": "test",
      "profile": "test",
      "command": { "program": "npm", "args": ["test"] },
      "artifact_expectation": "tests succeed",
      "required": true
    },
    {
      "label": "build",
      "profile": "build",
      "command": { "program": "npm", "args": ["run", "build"] },
      "artifact_expectation": "build succeeds",
      "required": true
    }
  ],
  "approval_mode": "never"
}
