{
  "pack_id": "python-fastapi-basic",
  "version": "1",
  "entry_goal": "implement one bounded Python FastAPI task",
  "recommended_verifier_flow": ["generic", "test"],
  "allowed_tools": [
    { "operation": "read_file", "scope": "workspace" },
    { "operation": "run_command", "scope": "workspace" }
  ],
  "verifier_rules": [
    {
      "label": "format",
      "profile": "generic",
      "command": { "program": "python3", "args": ["-m", "compileall", "app.py"] },
      "artifact_expectation": "format-style smoke succeeds",
      "required": true
    },
    {
      "label": "test",
      "profile": "test",
      "command": { "program": "python3", "args": ["-m", "unittest", "-q"] },
      "artifact_expectation": "unit tests succeed",
      "required": true
    },
    {
      "label": "import smoke",
      "profile": "generic",
      "command": { "program": "python3", "args": ["app.py"] },
      "artifact_expectation": "module imports cleanly",
      "required": true
    }
  ],
  "approval_mode": "never"
}
